---
const navLinks = [
  { href: '/resume', label: 'Resume' },
  { href: '/blog', label: 'Blog' },
  { href: 'https://github.com/JeromeAaron', label: 'GitHub', external: true },
  { href: 'https://www.linkedin.com/in/jerome-aaron/', label: 'LinkedIn', external: true },
];
---

<header class="border-b border-slate-800">
  <nav class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="font-mono text-cyan-400 font-bold text-lg hover:text-cyan-300 transition-colors">
      jerome-aaron
    </a>
    <ul class="flex items-center gap-6">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            class="text-slate-400 hover:text-slate-100 text-sm transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
