---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Not Found">
  <div class="py-20 text-center">
    <p class="font-mono text-cyan-400 text-sm mb-4">$ cat error.log</p>
    <h1 class="text-6xl font-bold text-slate-100 mb-4">404</h1>
    <p class="text-slate-400 mb-8">This page doesn't exist. Maybe it was never deployed.</p>
    <a href="/" class="font-mono text-sm text-cyan-400 hover:underline">← back to home</a>
  </div>
</Layout>
