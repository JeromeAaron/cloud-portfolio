---
import Layout from '../layouts/Layout.astro';

const skills = {
  'Cloud & Infrastructure': ['AWS', 'S3', 'CloudFront', 'Route 53', 'IAM', 'WAF', 'ACM', 'Terraform'],
  'DevOps & Automation': ['GitHub Actions', 'CI/CD', 'Git', 'Bash', 'Linux'],
  'IT & Security': ['Network Administration', 'Security+', 'ITIL v4', 'Active Directory'],
  'Web Technologies': ['Astro', 'HTML', 'CSS', 'JavaScript', 'Markdown'],
};

const certs = [
  { name: 'AWS Certified Solutions Architect – Associate', issuer: 'Amazon Web Services', badge: 'SAA-C03' },
  { name: 'CompTIA Security+', issuer: 'CompTIA', badge: 'SY0-701' },
  { name: 'ITIL® Foundations v4', issuer: 'PeopleCert', badge: 'ITIL4' },
  { name: 'CompTIA A+', issuer: 'CompTIA', badge: '220-1101/02' },
];
---

<Layout title="Resume">
  <div class="py-8">

    <p class="font-mono text-cyan-400 text-sm mb-2">$ cat resume.json</p>
    <h1 class="text-4xl font-bold text-slate-100 mb-2">Jerome Aaron</h1>
    <p class="text-slate-400 mb-10">
      Washington DC Metro Area ·
      <a href="https://github.com/JeromeAaron" target="_blank" rel="noopener noreferrer" class="text-cyan-400 hover:underline">GitHub</a>
      ·
      <a href="https://linkedin.com/in/jeromeaaron" target="_blank" rel="noopener noreferrer" class="text-cyan-400 hover:underline">LinkedIn</a>
    </p>

    <!-- Skills -->
    <section class="mb-12">
      <h2 class="font-mono text-cyan-400 text-sm mb-4">// skills</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {Object.entries(skills).map(([category, items]) => (
          <div class="bg-slate-900 border border-slate-800 rounded-lg p-5">
            <h3 class="text-slate-100 font-semibold mb-3 text-sm">{category}</h3>
            <div class="flex flex-wrap gap-2">
              {items.map(skill => (
                <span class="bg-slate-800 text-slate-300 text-xs px-2.5 py-1 rounded font-mono">{skill}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Certifications -->
    <section class="mb-12">
      <h2 class="font-mono text-cyan-400 text-sm mb-4">// certifications</h2>
      <div class="space-y-3">
        {certs.map(cert => (
          <div class="bg-slate-900 border border-slate-800 rounded-lg p-4 flex items-center justify-between">
            <div>
              <p class="text-slate-100 font-medium text-sm">{cert.name}</p>
              <p class="text-slate-400 text-xs mt-0.5">{cert.issuer}</p>
            </div>
            <span class="font-mono text-xs text-cyan-400 bg-slate-800 px-2.5 py-1 rounded shrink-0 ml-4">
              {cert.badge}
            </span>
          </div>
        ))}
      </div>
    </section>

    <!-- Experience -->
    <section class="mb-12">
      <h2 class="font-mono text-cyan-400 text-sm mb-4">// experience</h2>
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
        <div class="flex items-start justify-between mb-4">
          <div>
            <h3 class="text-slate-100 font-semibold">IT Specialist</h3>
            <p class="text-slate-400 text-sm mt-0.5">U.S. Small Business Administration · Washington DC Metro</p>
          </div>
          <span class="font-mono text-xs text-slate-500 bg-slate-800 px-2 py-1 rounded">GS-11</span>
        </div>
        <ul class="space-y-2 text-slate-300 text-sm">
          <li class="flex gap-2"><span class="text-cyan-400 shrink-0">▸</span> Add your key responsibilities here</li>
          <li class="flex gap-2"><span class="text-cyan-400 shrink-0">▸</span> Add your key responsibilities here</li>
          <li class="flex gap-2"><span class="text-cyan-400 shrink-0">▸</span> Add your key responsibilities here</li>
        </ul>
      </div>
    </section>

    <!-- Education -->
    <section class="mb-12">
      <h2 class="font-mono text-cyan-400 text-sm mb-4">// education</h2>
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
        <p class="text-slate-500 text-sm font-mono">// add your education here</p>
      </div>
    </section>

  </div>
</Layout>
